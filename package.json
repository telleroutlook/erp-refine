{
  "name": "erp-refine",
  "version": "0.1.0",
  "description": "AI-driven adaptive ERP platform with Refine + Cloudflare Workers",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build && cd ..",
    "deploy": "npm run build && wrangler deploy",
    "test": "vitest run",
    "test:sql": "vitest run tests/sql-validation.test.ts",
    "check:registry": "node scripts/check-registry.js",
    "schema:validate": "node scripts/validate-schema.js",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > src/types/database.ts",
    "lint": "eslint src/ --ext .ts,.tsx",
    "format": "prettier --write 'src/**/*.{ts,tsx}'"
  },
  "dependencies": {
    "ai": "^6.0.0",
    "@ai-sdk/anthropic": "^1.0.0",
    "@supabase/supabase-js": "^2.49.0",
    "hono": "^4.0.0",
    "zod": "^3.22.0",
    "jose": "^5.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0",
    "better-sqlite3": "^12.0.0",
    "wrangler": "^4.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0"
  }
}
